{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wanazhar/blackbox/spec/schemas/boundary.v1.json",
  "title": "Blackbox resolved boundary v1",
  "type": "object",
  "required": ["schema", "run_id", "policy_hash", "resolved_at", "contract"],
  "properties": {
    "schema": {"const": "blackbox.boundary/v1"},
    "run_id": {"type": "string"},
    "policy_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "resolved_at": {"type": "string", "pattern": "Z$"},
    "contract": {"type": "object"},
    "inheritance_chain": {"type": "array", "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
  },
  "additionalProperties": true
}
