{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wanazhar/blackbox/spec/schemas/event.v1.json",
  "title": "blackbox.event/v1",
  "type": "object",
  "required": ["schema", "id", "run_id", "sequence", "kind", "started_at"],
  "properties": {
    "schema": { "const": "blackbox.event/v1" },
    "id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "parent_event_id": { "type": ["string", "null"] },
    "sequence": { "type": "integer", "minimum": 0 },
    "source": { "type": "string" },
    "kind": { "type": "string", "minLength": 1 },
    "started_at": { "type": "string", "pattern": "Z$" },
    "ended_at": { "type": ["string", "null"], "pattern": "Z$" },
    "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
    "status": { "type": "string" },
    "side_effect": { "type": "string" },
    "input_blob": { "type": ["string", "null"] },
    "output_blob": { "type": ["string", "null"] },
    "error_blob": { "type": ["string", "null"] },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true
}
