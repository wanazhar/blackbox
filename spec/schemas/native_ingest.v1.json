{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wanazhar/blackbox/spec/schemas/native_ingest.v1.json",
  "title": "blackbox.native.ingest/v1",
  "type": "object",
  "required": ["schema", "op", "idempotency_key"],
  "properties": {
    "schema": { "const": "blackbox.native.ingest/v1" },
    "op": {
      "type": "string",
      "enum": [
        "start_run",
        "record_event",
        "record_tool",
        "record_model",
        "record_handoff",
        "record_approval",
        "record_security_decision",
        "attach_evidence",
        "finish_run",
        "ack"
      ]
    },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "run_id": { "type": ["string", "null"] },
    "payload": { "type": "object" },
    "producer": { "type": ["string", "null"] },
    "client_seq": { "type": ["integer", "null"], "minimum": 0 }
  },
  "additionalProperties": true
}
