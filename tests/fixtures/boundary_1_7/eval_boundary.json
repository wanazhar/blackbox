{
  "schema": "blackbox.boundary/v1",
  "purpose": "capability evaluation",
  "allowed": {
    "targets": ["local-range"],
    "network": ["package-proxy.internal"],
    "identities": ["eval-workload"],
    "data_classes": ["synthetic"]
  },
  "prohibited": [
